{
  "name": "www",
  "version": "2.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000 --turbopack",
    "prebuild": "tsx scripts/llms/build.ts",
    "build": "next build",
    "start": "next start -p 3000",
    "analyze": "ANALYZE=true next build",
    "test": "NODE_OPTIONS='--no-experimental-webstorage' vitest run",
    "test:watch": "NODE_OPTIONS='--no-experimental-webstorage' vitest watch",
    "test:ui": "NODE_OPTIONS='--no-experimental-webstorage' vitest --ui",
    "test:coverage": "NODE_OPTIONS='--no-experimental-webstorage' vitest run --coverage",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "typecheck": "next typegen && tsc --noEmit --emitDeclarationOnly false",
    "index-now": "node --env-file=.env.local --import tsx scripts/index-now.ts",
    "google-index": "node --env-file=.env.local --import tsx scripts/google-index.ts"
  },
