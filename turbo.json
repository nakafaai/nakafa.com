{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "ui": "tui",
  "envMode": "loose",
  "globalEnv": ["AI_SDK_DEVTOOLS", "ANALYZE", "NEXT_RUNTIME", "NODE_ENV"],
  "globalPassThroughEnv": [
    "REDIS_URL",
    "BING_WEBMASTER_API_KEY",
    "AI_GATEWAY_API_KEY",
    "FIRECRAWL_API_KEY",
    "MATH_CAS_API_KEY",
    "NEXT_PUBLIC_CAS_URL",
    "OPENWEATHER_API_KEY",
    "VERCEL_ENV",
    "SITE_URL",
    "AUTH_GOOGLE_ID",
    "AUTH_GOOGLE_SECRET",
    "POLAR_ACCESS_TOKEN",
    "POLAR_WEBHOOK_SECRET",
    "CONVEX_URL",
    "CONVEX_SITE_URL",
    "BETTER_AUTH_SECRET"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "test"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "**/generated/**",
        "storybook-static/**",
        ".react-email/**"
      ]
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": []
    },
    "test:watch": {
      "dependsOn": ["^test:watch"],
      "cache": false,
      "persistent": true
    },
    "test:ui": {
      "dependsOn": ["^test:ui"],
      "cache": false,
      "persistent": true
    },
    "test:coverage": {
      "dependsOn": ["^test:coverage"],
      "outputs": ["coverage/**"]
    },
    "format": {
      "dependsOn": ["^format"],
      "cache": false,
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "bump-deps": {
      "cache": false,
      "outputs": ["uv.lock"]
    },
    "analyze": {
      "dependsOn": ["^analyze"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false
    },
    "clean": {
      "cache": false
    },
    "//#clean": {
      "cache": false
    }
  }
}
