{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "ultracite": {
      "type": "remote",
      "url": "https://docs.ultracite.ai/mcp"
    },
    "posthog": {
      "type": "remote",
      "url": "https://mcp-eu.posthog.com/mcp",
      "headers": {
        "Authorization": "Bearer {env:POSTHOG_MCP_API_KEY}"
      }
    },
    "convex": {
      "type": "local",
      "command": ["npx", "-y", "convex@latest", "mcp", "start"]
    }
  }
}
