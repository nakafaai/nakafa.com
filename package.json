{
  "name": "nakafa",
  "version": "1.0.2",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "bin": {
    "nakafa": "dist/index.js"
  },
  "files": [
    "dist/index.js"
  ],
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=www --filter=@repo/backend --filter=cas",
    "dev:web": "turbo run dev --filter=www --filter=@repo/backend --filter=cas",
    "dev:all": "turbo run dev",
    "start": "turbo run start",
    "lint": "ultracite check && turbo run lint --filter=cas",
    "format": "ultracite fix && turbo run format --filter=cas",
    "format:doctor": "ultracite doctor",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:ui": "turbo run test:ui",
    "test:coverage": "turbo run test:coverage",
    "analyze": "turbo run analyze",
    "translate": "turbo run translate",
    "boundaries": "turbo boundaries",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "bump-deps": "pnpm dlx npm-check-updates --deep -u -x pnpm,better-auth && turbo run bump-deps --filter=cas",
    "bump-ui": "pnpm dlx shadcn@latest add --all --overwrite -c packages/design-system",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules .cache apps/*/.cache packages/*/.cache .pnpm-store apps/*/.turbo packages/*/.turbo apps/*/.ruff_cache apps/*/.pytest_cache apps/*/.venv apps/*/.coverage .turbo .next apps/*/.next apps/*/.react-email packages/*/.react-email .vercel/output apps/*/.vercel/output coverage apps/*/coverage packages/*/coverage && find apps packages -name __pycache__ -type d -prune -exec rm -rf {} +",
    "clean:ts": "find . -name '*.tsbuildinfo' -type f -delete && find . -name 'tsconfig.tsbuildinfo' -type f -delete",
    "deps-check-www": "cd apps/www && depcheck --ignore-dirs=node_modules || true",
    "deps-check-api": "cd apps/api && depcheck --ignore-dirs=node_modules || true",
    "deps-check-mcp": "cd apps/mcp && depcheck --ignore-dirs=node_modules || true",
    "doctor": "pnpm dlx react-doctor@latest"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@effect/language-service": "^0.86.2",
    "@repo/typescript-config": "workspace:*",
    "@turbo/gen": "^2.9.16",
    "@types/node": "^25.9.2",
    "@vercel/config": "^0.5.1",
    "depcheck": "^1.4.7",
    "tsup": "^8.5.1",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "ultracite": "^7.8.1"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.0.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": "^24.0.0"
  },
  "packageManager": "pnpm@10.34.1",
  "type": "module"
}
