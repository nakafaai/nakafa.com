{
  "name": "nakafa",
  "version": "1.0.0",
  "bin": {
    "nakafa": "dist/index.js"
  },
  "files": [
    "dist/index.js"
  ],
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=www --filter=@repo/backend",
    "dev:web": "turbo run dev --filter=www --filter=@repo/backend",
    "dev:all": "turbo run dev",
    "start": "turbo run start",
    "lint": "ultracite check",
    "format": "ultracite fix",
    "format:doctor": "ultracite doctor",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:ui": "turbo run test:ui",
    "test:coverage": "turbo run test:coverage",
    "analyze": "turbo run analyze",
    "translate": "turbo run translate",
    "boundaries": "turbo run boundaries",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "bump-deps": "pnpm dlx npm-check-updates --deep -u -x recharts,better-auth",
    "bump-ui": "pnpm dlx shadcn@latest add --all --overwrite -c packages/design-system",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/.turbo packages/*/.turbo .turbo .next apps/*/.next apps/*/.react-email packages/*/.react-email coverage apps/*/coverage packages/*/coverage",
    "clean:ts": "find . -name '*.tsbuildinfo' -type f -delete && find . -name 'tsconfig.tsbuildinfo' -type f -delete",
    "deps-check-www": "cd apps/www && depcheck --ignore-dirs=node_modules || true",
    "deps-check-api": "cd apps/api && depcheck --ignore-dirs=node_modules || true",
    "deps-check-mcp": "cd apps/mcp && depcheck --ignore-dirs=node_modules || true"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@effect/language-service": "^0.85.1",
    "@repo/typescript-config": "workspace:*",
    "@turbo/gen": "^2.9.6",
    "@types/node": "^25.6.0",
    "depcheck": "^1.4.7",
    "tsup": "^8.5.1",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "ultracite": "^7.6.1"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.2",
  "type": "module"
}
