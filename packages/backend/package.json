{
  "name": "@repo/backend",
  "version": "2.0.1",
  "private": true,
  "scripts": {
    "dev": "convex dev --tail-logs",
    "setup": "convex dev --once && convex env set VALIDATE_ENV=true",
    "seed": "convex dev --once && convex run init",
    "deploy": "convex deploy",
    "insights": "convex insights",
    "generate-schema": "cd convex/betterAuth && AUTH_GOOGLE_ID=schema-generation AUTH_GOOGLE_SECRET=schema-generation pnpm dlx auth@1.6.9 generate --output generatedSchema.ts --yes",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "test": "vitest run",
    "test:once": "vitest run",
    "test:watch": "vitest watch",
    "test:debug": "vitest --inspect-brk --no-file-parallelism",
    "test:coverage": "vitest run --coverage",
    "customers:verify": "tsx scripts/customers/verify.ts",
    "customers:verify:prod": "tsx scripts/customers/verify.ts --prod",
    "customers:repair": "tsx scripts/customers/repair.ts",
    "customers:repair:prod": "tsx scripts/customers/repair.ts --prod",
    "tryout:verify:access": "tsx scripts/tryout/access.ts",
    "tryout:repair:access": "convex run tryoutAccess/mutations/internal/status:sweepStates {}",
    "tryout:verify:access:prod": "tsx scripts/tryout/access.ts --prod",
    "tryout:repair:access:prod": "convex run tryoutAccess/mutations/internal/status:sweepStates {} --prod",
    "irt:verify:cache": "tsx scripts/irt-verify.ts cache",
    "irt:verify:queue": "tsx scripts/irt-verify.ts queue",
    "irt:verify:scale": "tsx scripts/irt-verify.ts scale",
    "irt:prod:verify:cache": "tsx scripts/irt-verify.ts cache --prod",
    "irt:prod:verify:queue": "tsx scripts/irt-verify.ts queue --prod",
    "irt:prod:verify:scale": "tsx scripts/irt-verify.ts scale --prod",
    "sync": "tsx scripts/sync-content.ts full",
    "sync:incremental": "tsx scripts/sync-content.ts incremental",
    "sync:validate": "tsx scripts/sync-content.ts validate",
    "sync:verify": "tsx scripts/sync-content.ts verify",
    "sync:clean": "tsx scripts/sync-content.ts clean",
    "sync:reset": "tsx scripts/sync-content.ts reset",
    "sync:reset:tryouts": "tsx scripts/sync-content.ts reset-tryouts",
    "sync:prod": "tsx scripts/sync-content.ts full --prod",
    "sync:prod:incremental": "tsx scripts/sync-content.ts incremental --prod",
    "sync:prod:verify": "tsx scripts/sync-content.ts verify --prod",
    "sync:prod:clean": "tsx scripts/sync-content.ts clean --prod",
    "sync:prod:reset": "tsx scripts/sync-content.ts reset --prod",
    "sync:prod:reset:tryouts": "tsx scripts/sync-content.ts reset-tryouts --prod"
  },
  "dependencies": {
    "@convex-dev/aggregate": "^0.2.1",
    "@convex-dev/better-auth": "^0.12.2",
    "@convex-dev/resend": "^0.2.4",
    "@convex-dev/workflow": "^0.4.2",
    "@convex-dev/workpool": "^0.4.6",
    "@polar-sh/sdk": "^0.47.1",
    "@posthog/convex": "1.0.7",
    "@repo/ai": "workspace:*",
    "@repo/math": "workspace:*",
    "@repo/utilities": "workspace:*",
    "@t3-oss/env-nextjs": "^0.13.11",
    "ai": "^6.0.191",
    "better-auth": "~1.6.9",
    "buffer": "^6.0.3",
    "convex": "^1.39.1",
    "convex-helpers": "^0.1.118",
    "effect": "^3.21.2",
    "hono": "^4.12.23",
    "jsonrepair": "^3.14.0",
    "nanoid": "^5.1.11",
    "strip-ansi": "^7.2.0"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@repo/contents": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@vitest/coverage-istanbul": "^4.1.7",
    "convex-test": "^0.0.53",
    "glob": "^13.0.6",
    "tsx": "^4.22.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
